# Environment for the app container. Injected by docker-compose (env_file) and
# also copied to .env on first boot so `key:generate` has a file to write to.
# NOTE: deliberately NO APP_KEY here — it is generated into .env on first boot.
# APP_ENV / APP_DEBUG / APP_URL are set by docker-compose.yml (so the same image
# is safe in production); override APP_URL via a host .env file when deploying.
APP_NAME="HR Tool"

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Bundled PostgreSQL (the `db` service). This is the single change that points
# the app at a working database instead of the broken MySQL default.
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=employees_management
DB_USERNAME=hr
DB_PASSWORD=hr

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Mail -> bundled Mailpit. MAIL_ENCRYPTION MUST stay empty: config/mail.php
# defaults it to "tls", but Mailpit:1025 is plaintext, so a non-empty value
# makes the first inline mail send (e.g. Add Employee) 500 on the TLS handshake.
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS=hr@localhost
MAIL_FROM_NAME="HR Tool"

# Unused at runtime — left blank intentionally.
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
